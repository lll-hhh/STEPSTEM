    "step_11": {
      "modality": "text",
      "content": "Substitute (A) into (2.3.8b): \\(\\frac{R_2}{R_1R_3}(i_LZ_L-v_s)=i_L+\\frac{i_LZ_L}{R_4}\\).",
      "key_point": "Eliminate \\(v_o\\)."
