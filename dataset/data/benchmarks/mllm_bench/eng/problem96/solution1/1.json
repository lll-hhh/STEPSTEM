    "step_2": {
      "modality": "text",
      "content": "Because \\(v_p=v_L=i_LZ_L\\), we get \\(v_n=i_LZ_L\\).",
      "key_point": "Express node voltage by \\(i_LZ_L\\)."
    },
    "step_3": {
