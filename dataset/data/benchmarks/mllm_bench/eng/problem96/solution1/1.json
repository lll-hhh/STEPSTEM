    "step_7": {
      "modality": "text",
      "content": "Rearrange (2.3.8a): \\(v_o-i_LZ_L=\\frac{R_2}{R_1}(i_LZ_L-v_s)\\) (A).",
      "key_point": "Isolate \\(v_o-i_LZ_L\\)."
    },
    "step_8": {
      "modality": "text",
      "content": "At output branch, \\(i_3=i_4+i_L\\): \\(\\frac{v_o-v_L}{R_3}=i_L+\\frac{v_L}{R_4}\\).",
      "key_point": "Write output-node KCL."
    },
    "step_9": {
      "modality": "text",
